generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("POSTGRES_PRISMA_URL")
  directUrl  = env("POSTGRES_URL_NON_POOLING")
  extensions = [citext(schema: "public")]
}

enum Badge {
  ADMIN
  PATRON
  USER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum RoomType {
  CASUAL      
  RECURRING   
  VENUE       
}

enum RoomVisibility {
  PUBLIC      
  LINK_ONLY   
  INVITE_ONLY 
}

enum SessionStatus {
  SCHEDULED  
  ACTIVE     
  CLOSED     
}

enum AchievementCategory {
  LIBRARY     
  GEOGRAPHY   
  CATEGORY    
  MECHANIC    
  COMPLEXITY  
  RATINGS     
  SOCIAL      
  PLAY        
  STREAK      
}

model Users {
  id           Int     @id @default(autoincrement())
  username     String  @unique @db.Citext
  password     String
  firstName    String?
  lastName     String?
  email        String?
  location     String?
  website      String?
  bio          String?
  image        String?
  badge        Badge   @default(USER)
  joinDate     DateTime @default(now())

  following        Following[]             @relation("Follower")
  followedBy       Following[]             @relation("Following")
  invitedRooms     RoomInvites[]
  hostedRooms      Rooms[]                 @relation("HostRooms")
  ratings          UserGameRatings[]
  collection       UserGames[]             @relation("UserGames")
  roomVotes        RoomGameVotes[]
  gameSuggestions  RoomGameSuggestions[]   @relation("SuggestedByUser")
  achievements     UserAchievements[]
  gameSessions     GameSessionPlayers[]
  hostedSessions   RoomSessions[]          @relation("SessionHost")
}

model Following {
  userId          Int
  followingUserId Int
  addedAt         DateTime @default(now())

  user      Users @relation("Follower",  fields: [userId],          references: [id], onDelete: Cascade)
  following Users @relation("Following", fields: [followingUserId], references: [id], onDelete: Cascade)

  @@id([userId, followingUserId])
}

model Games {
  id          Int      @id @default(autoincrement())
  addedAt     DateTime @default(now())
  bggId       Int?     @unique
  name        String
  description String?
  imageUrl    String?
  minPlaytime Int
  maxPlaytime Int
  minPlayers  Int
  maxPlayers  Int
  complexity  Float?
  bggRating   Float?
  yearPublished Int?
  categories  String[]  
  mechanics   String[]  
  designers   String[]  
  publishers  String[]  
  countries   String[]
  bggLastSynced DateTime?

  roomGames         RoomGameSuggestions[]
  roomVotes         RoomGameVotes[]
  roomPermanent     RoomPermanentGames[]
  ratings           UserGameRatings[]
  users             UserGames[]             @relation("UserGames")
  sessionGames      GameSessionGames[]
}

model UserGames {
  id      Int      @id @default(autoincrement())
  userId  Int
  gameId  Int
  addedAt DateTime @default(now())
  notes   String?
  weight  Int      @default(1)
  isWishlist Boolean @default(false)
  isFavorite Boolean @default(false)

  game    Games    @relation("UserGames", fields: [gameId], references: [id], onDelete: Cascade)
  user    Users    @relation("UserGames", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model UserGameRatings {
  id      Int      @id @default(autoincrement())
  userId  Int
  gameId  Int
  stars   Int      @db.SmallInt
  review  String?
  ratedAt DateTime @default(now())

  game    Games    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user    Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model Rooms {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  hostId        Int
  createdAt     DateTime       @default(now())
  isActive      Boolean        @default(true)
  isCompetitive Boolean        @default(true)
  code          String         @unique
  type          RoomType       @default(CASUAL)
  visibility    RoomVisibility @default(PUBLIC)
  expiresAt     DateTime?
  lastOpenedAt  DateTime?
  playerCount   Int?
  timeBudget    Int?

  host              Users                 @relation("HostRooms", fields: [hostId], references: [id])
  gameSuggs         RoomGameSuggestions[]
  invites           RoomInvites[]
  votes             RoomGameVotes[]
  permanentGames    RoomPermanentGames[]
  sessions          RoomSessions[]
}

model RoomInvites {
  id        Int          @id @default(autoincrement())
  roomId    Int
  userId    Int
  status    InviteStatus @default(PENDING)
  invitedAt DateTime     @default(now())

  room      Rooms        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      Users        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model RoomPermanentGames {
  id      Int      @id @default(autoincrement())
  roomId  Int
  gameId  Int
  addedBy Int
  addedAt DateTime @default(now())

  room    Rooms    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  game    Games    @relation(fields: [gameId], references: [id])

  @@unique([roomId, gameId])
}

model RoomSessions {
  id          Int           @id @default(autoincrement())
  roomId      Int
  hostId      Int
  status      SessionStatus @default(SCHEDULED)
  scheduledFor DateTime?    
  openedAt    DateTime?     
  closedAt    DateTime?     
  playerCount Int?          
  notes       String?       

  room        Rooms         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  host        Users         @relation("SessionHost", fields: [hostId], references: [id])
  gamePlayed  GameSessions[]
}

model RoomGameSuggestions {
  id          Int      @id @default(autoincrement())
  roomId      Int
  gameId      Int
  createdAt   DateTime @default(now())

  suggestedBy   Int?
  suggestedUser Users?  @relation("SuggestedByUser", fields: [suggestedBy], references: [id], onDelete: SetNull)

  game        Games    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  room        Rooms    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, gameId])
}

model RoomGameVotes {
  id         Int      @id @default(autoincrement())
  roomId     Int
  gameId     Int
  userId     Int
  interested Boolean
  votedAt    DateTime @default(now())

  room       Rooms    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  game       Games    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user       Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, gameId, userId])
}

model GameSessions {
  id          Int       @id @default(autoincrement())
  playedAt    DateTime  @default(now())
  durationMin Int?      
  notes       String?
  roomSessionId Int?
  roomSession   RoomSessions? @relation(fields: [roomSessionId], references: [id], onDelete: SetNull)

  games       GameSessionGames[]
  players     GameSessionPlayers[]
}

model GameSessionGames {
  id            Int          @id @default(autoincrement())
  gameSessionId Int
  gameId        Int

  gameSession   GameSessions @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  game          Games        @relation(fields: [gameId],        references: [id])

  @@unique([gameSessionId, gameId])
}


model GameSessionPlayers {
  id            Int          @id @default(autoincrement())
  gameSessionId Int
  userId        Int
  won           Boolean?     

  gameSession   GameSessions @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  user          Users        @relation(fields: [userId],        references: [id])

  @@unique([gameSessionId, userId])
}


model Achievements {
  id          Int                 @id @default(autoincrement())
  key         String              @unique  
  name        String                       
  description String                       
  category    AchievementCategory
  icon        String                      
  points      Int                 @default(10)
  threshold   Int?
  isSecret    Boolean             @default(false)
  sortOrder   Int                 @default(0)

  users       UserAchievements[]
}

model UserAchievements {
  id            Int          @id @default(autoincrement())
  userId        Int
  achievementId Int
  earnedAt      DateTime     @default(now())
  progress      Int?

  user          Users        @relation(fields: [userId],        references: [id], onDelete: Cascade)
  achievement   Achievements @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}
